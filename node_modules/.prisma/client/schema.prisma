// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum ProposalStatus {
  PENDING
  APPROVED
  REJECTED
  REVISION_REQUIRED
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      UserRole
  createdAt DateTime @default(now())

  studentProposals    Proposal[] @relation("StudentProposals")
  supervisorProposals Proposal[] @relation("SupervisorProposals")
  comments            Comment[]
}

model Proposal {
  id           Int            @id @default(autoincrement())
  title        String
  abstract     String
  status       ProposalStatus
  documentUrl  String
  studentId    Int
  supervisorId Int
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  student    User      @relation("StudentProposals", fields: [studentId], references: [id])
  supervisor User      @relation("SupervisorProposals", fields: [supervisorId], references: [id])
  comments   Comment[]
}

model Comment {
  id          Int      @id @default(autoincrement())
  content     String
  proposalId  Int
  commenterId Int
  createdAt   DateTime @default(now())

  proposal  Proposal @relation(fields: [proposalId], references: [id])
  commenter User     @relation(fields: [commenterId], references: [id])
}

model Session {
  id        Int      @id @default(autoincrement())
  name      String
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
}
